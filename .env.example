# ElevenLabs API key
# Sign up at https://elevenlabs.io and find your key under Profile > API Keys
ELEVENLABS_API_KEY=your_api_key_here

# Optional: Voice ID (defaults to Lily - British female, warm tone)
# Browse voices at https://elevenlabs.io/voice-library
# ELEVENLABS_VOICE_ID=pFZP5JQG7iQjIQuC4Bku

# Optional: TTS model (defaults to eleven_turbo_v2 for lowest latency)
# ELEVENLABS_MODEL=eleven_turbo_v2
